<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item>
        <shape>
            <solid android:color="@color/shadowColor" />
            <corners android:radius="@dimen/radius_m" />
        </shape>
    </item>
    <!-- Content -->
    <item android:bottom="@dimen/elevation_s">
        <shape>
            <solid android:color="@color/backgroundCard" />
            <corners android:radius="@dimen/radius_m" />
        </shape>
    </item>
</layer-list>
